# Токен бота из @BotFather
BOT_TOKEN=123456:PASTE_YOUR_TOKEN_HERE

# Telegram ID администраторов через запятую.
# Узнать ID можно у бота @userinfobot
TELEGRAM_ADMIN_IDS=123456789,987654321

# Файл базы данных. Для Docker лучше оставить путь ниже.
DATABASE_PATH=/app/data/dnd_bot.sqlite3

# Необязательно: название кампании
CAMPAIGN_NAME=DnD Campaign
